    if loc.name:match("^Trial Mob %d+$") then
        table.insert(trialMobLocations, loc)
    end
end
table.sort(trialMobLocations, function(a, b)
    return tonumber(a.name:match("%d+")) < tonumber(b.name:match("%d+"))
end)

-- ===== TELEPORT FUNCTION =====
local function teleportTo(loc)
    local character = player.Character
    if not character then
        print("[TeleportGui] Teleport failed: no character found")
        return
    end
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    if not hrp then
        print("[TeleportGui] Teleport failed: no HumanoidRootPart found")
        return
    end
    hrp.CFrame = CFrame.new(loc.x, loc.y, loc.z)
    print("[TeleportGui] Teleported to " .. (loc.name or "void") .. " at " .. os.date("%X"))
end

-- ===== KILL CHARACTER FUNCTION =====
local function endCharacter()
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    teleportTo(voidLocation)
    if humanoid then
        humanoid.Health = 0
        print("[TeleportGui] Farm timer expired — character ended at " .. os.date("%X"))
    end
end

-- ===== LOOP STATE =====
local looping = false
local loopDelay = 2
local loopToggleButton -- forward declared

local function startLoop()
    if looping then return end
    looping = true
    print("[TeleportGui] Trial Mob loop STARTED at " .. os.date("%X"))
    task.spawn(function()
        while looping do
            for _, loc in ipairs(trialMobLocations) do
                if not looping then break end
                teleportTo(loc)
                task.wait(loopDelay)
            end
        end
    end)
end

local function stopLoop()
    looping = false
    print("[TeleportGui] Trial Mob loop STOPPED at " .. os.date("%X"))
end

-- ===== FARM DURATION TIMER =====
local farmDurationMinutes = 3
local farmTimerId = 0 -- used to invalidate old timers when restarted/cancelled

local function startFarmTimer()
    farmTimerId += 1
    local myTimerId = farmTimerId
    local durationSeconds = farmDurationMinutes * 60
    print(string.format("[TeleportGui] Farm timer started: %d min (%ds)", farmDurationMinutes, durationSeconds))

    task.delay(durationSeconds, function()
        if myTimerId ~= farmTimerId then return end -- timer was cancelled/replaced
        print("[TeleportGui] Farm duration reached — stopping loop and ending run")
        stopLoop()
        if loopToggleButton then
            loopToggleButton.Text = "▶ Start Trial Mob Loop"
            loopToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        end
        endCharacter()
    end)
end

local function cancelFarmTimer()
    farmTimerId += 1 -- invalidates any pending task.delay callback
end

-- ===== AFK FARM SCHEDULE (every hour, real-life time) =====
-- :28/:58 -> teleport to Hub
-- :29/:59 -> start Trial Mob loop + start farm duration timer
local afkFarmEnabled = false
local lastTriggeredMinuteKey = nil
local afkFarmButton -- forward declared

task.spawn(function()
    while true do
        if afkFarmEnabled then
            local t = os.date("*t")
            local key = os.date("%Y-%m-%d-%H-%M")

            print(string.format("[AFK Farm] Checking... current time = %s (min=%d)", os.date("%X"), t.min))

            if key ~= lastTriggeredMinuteKey then
                if t.min == 28 or t.min == 58 then
                    print("[AFK Farm] Trigger match: :28/:58 -> teleporting to Hub")
                    teleportTo(hubLocation)
                    lastTriggeredMinuteKey = key

                elseif t.min == 29 or t.min == 59 then
                    print("[AFK Farm] Trigger match: :29/:59 -> starting loop + farm timer")
                    if not looping then
                        startLoop()
                        startFarmTimer()
                        if loopToggleButton then
                            loopToggleButton.Text = "■ Stop Loop"
                            loopToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
                        end
                    end
                    lastTriggeredMinuteKey = key
                end
            end
        end
        task.wait(1)
    end
end)

