-- ===== TELEPORT FUNCTION =====
local function teleportTo(loc)
    local character = player.Character
    if not character then
        print("[TeleportGui] Teleport failed: no character found")
        return
    end
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    if not hrp then
        print("[TeleportGui] Teleport failed: no HumanoidRootPart found")
        return
    end
    hrp.CFrame = CFrame.new(loc.x, loc.y, loc.z)
    print("[TeleportGui] Teleported to " .. (loc.name or "unknown") .. " at " .. os.date("%X"))
end

-- ===== SAVED POSITION (for End Trial / auto-return) =====
local savedOriginalPosition = nil

local function saveCurrentPosition()
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        savedOriginalPosition = hrp.CFrame
        print("[TeleportGui] Saved original position at " .. os.date("%X"))
    end
end

local function returnToSavedPosition()
    if not savedOriginalPosition then
        print("[TeleportGui] No saved position to return to")
        return
    end
    local character = player.Character
    if not character then return end
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    if hrp then
        hrp.CFrame = savedOriginalPosition
        print("[TeleportGui] Returned to original position at " .. os.date("%X"))
    end
end

