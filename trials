-- ===== AUTO-RETURN TIMER (user-configurable, capped 1-30 min, toggleable) =====
local autoReturnMinutes = 25 -- default; user can change via GUI, clamped 1-30
local autoReturnEnabled = true -- toggle on/off
local autoReturnTimerId = 0
local autoReturnButton, setAutoReturnButtonColor -- forward declared

local function stopEverythingAndReturn()
    stopLoop()
    stopHardLoop()
    resetLoopButtonVisual()
    resetHardLoopButtonVisual()
    returnToSavedPosition()
end

local function startAutoReturnTimer()
    if not autoReturnEnabled then
        print("[TeleportGui] Auto-return is OFF -> not starting timer")
        return
    end

    autoReturnTimerId += 1
    local myTimerId = autoReturnTimerId
    local durationSeconds = autoReturnMinutes * 60
    print(string.format("[TeleportGui] Auto-return timer started: %d min", autoReturnMinutes))

    task.delay(durationSeconds, function()
        if myTimerId ~= autoReturnTimerId then return end -- superseded by a newer cycle
        if not autoReturnEnabled then
            print("[TeleportGui] Auto-return timer fired but feature is OFF -> skipping")
            return
        end
        print(string.format("[TeleportGui] %d minutes elapsed -> stopping loops and returning to original position", autoReturnMinutes))
        stopEverythingAndReturn()
    end)
end

local function cancelAutoReturnTimer()
    autoReturnTimerId += 1
end

-- ===== SHARED HUB-STAGING HELPER =====
-- Repeatedly teleports to a staging point for HUB_REPEAT_DURATION seconds,
-- waits, then starts the given loop and the auto-return timer.
local HUB_REPEAT_DURATION = 15  -- seconds
local HUB_REPEAT_INTERVAL = 1   -- seconds between each teleport

local function runAfkStagingSequence(stagingLocation, startLoopFn, loopButton, setLoopButtonColorFn, stopLoopBtnText, tag)
    print(string.format("[%s] Trigger match: :29/:59 -> saving position, staging at %s", tag, stagingLocation.name))
    saveCurrentPosition()

    local elapsed = 0
    while elapsed < HUB_REPEAT_DURATION do
        teleportTo(stagingLocation)
        task.wait(HUB_REPEAT_INTERVAL)
        elapsed += HUB_REPEAT_INTERVAL
    end
    print(string.format("[%s] Done staging -> waiting 10s before starting loop", tag))
    task.wait(10)
    print(string.format("[%s] Wait done -> starting loop and auto-return timer", tag))

    startLoopFn()
    if loopButton then
        loopButton.Text = stopLoopBtnText
        setLoopButtonColorFn(Color3.fromRGB(231, 76, 60))
    end
    startAutoReturnTimer()
end

