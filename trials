-- ===== Helper: creates a TOGGLE-safe button (fixes the stuck-color bug) =====
local function createToggleButton(text, initialColor, layoutOrder, height)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, height or 36)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.GothamBold
    button.TextSize = 14
    button.Text = text
    button.AutoButtonColor = false
    button.LayoutOrder = layoutOrder
    button.BackgroundColor3 = initialColor
    button.Parent = scrollFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = button

    local btnStroke = Instance.new("UIStroke")
    btnStroke.Color = Color3.fromRGB(255, 255, 255)
    btnStroke.Transparency = 0.85
    btnStroke.Thickness = 1
    btnStroke.Parent = button

    button:SetAttribute("BaseColor", initialColor)

    button.MouseEnter:Connect(function()
        local base = button:GetAttribute("BaseColor")
        TweenService:Create(button, TweenInfo.new(0.15), {
            BackgroundColor3 = base:Lerp(Color3.new(1, 1, 1), 0.15)
        }):Play()
    end)
    button.MouseLeave:Connect(function()
        local base = button:GetAttribute("BaseColor")
        TweenService:Create(button, TweenInfo.new(0.15), {
            BackgroundColor3 = base
        }):Play()
    end)

    local function setColor(color)
        button:SetAttribute("BaseColor", color)
        button.BackgroundColor3 = color
    end

    return button, setColor
end

