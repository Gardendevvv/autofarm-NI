local function collectSorted(pattern)
    local list = {}
    for _, loc in ipairs(locations) do
        if loc.name:match(pattern) then
            table.insert(list, loc)
        end
    end
    table.sort(list, function(a, b)
        return tonumber(a.name:match("%d+")) < tonumber(b.name:match("%d+"))
    end)
    return list
end

local trialMobLocations = collectSorted("^Trial Mob %d+$")
